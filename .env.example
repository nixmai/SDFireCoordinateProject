# Power Automate: HTTP trigger URL from your flow (When a HTTP request is received)
POWER_AUTOMATE_WEBHOOK_URL=https://your-environment.api.powerplatform.com/.../triggers/manual/paths/invoke?api-version=1&...

# Optional: Microsoft Teams incoming webhook
# TEAMS_WEBHOOK_URL=https://example.webhook.office.com/webhookb2/...

# Counties to watch (comma-separated, lowercase). Empty = all California.
MONITOR_COUNTIES=san diego

# How often the background agent checks (minutes).
CHECK_INTERVAL_MINUTES=5
